{
  "name": "architecture-v3",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm css-types:build && vite",
    "build": "pnpm css-types:build && tsc && vite build",
    "preview": "vite preview",
    "check": "biome check --write src",
    "lint": "biome lint --write src",
    "format": "biome format --write src && prettier --write \"src/**/*.scss\"",
    "css-types": "typed-scss-modules \"src/**/*.module.scss\" --watch --implementation sass --aliasPrefixes.@ src",
    "css-types:build": "typed-scss-modules \"src/**/*.module.scss\" --implementation sass --aliasPrefixes.@ src",
    "prepare": "husky",
    "commit": "cz",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@sentry/react": "^10.48.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.22",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.3",
    "sass": "^1.99.0",
    "sonner": "^2.0.7",
    "valibot": "^1.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.22",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "happy-dom": "20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.3",
    "postcss": "^8.5.9",
    "prettier": "^3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "size-limit": "^12.1.0",
    "typed-scss-modules": "^8.1.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-checker": "^0.13.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{scss,css}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "size-limit": [
    {
      "name": "App entry (JS, gzip)",
      "path": "dist/assets/index-*.js",
      "limit": "275 KB",
      "gzip": true
    },
    {
      "name": "Total JS (gzip)",
      "path": "dist/assets/*.js",
      "limit": "320 KB",
      "gzip": true
    },
    {
      "name": "Total CSS (gzip)",
      "path": "dist/assets/*.css",
      "limit": "10 KB",
      "gzip": true
    }
  ]
}
